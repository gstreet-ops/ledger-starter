# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database — MUST use Session Pooler URL (port 6543), not Direct (port 5432)
# Find in Supabase: Project home → Connect → Session pooler tab
DATABASE_URL=postgresql://postgres.your-project-id:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Plaid (optional — skip if CSV-only)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLAID_TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key

# Anthropic (optional — needed for AI categorization and narrative reports)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Demo mode (optional — for running a public demo instance)
# DEMO_EMAIL=demo@your-app.app
# DEMO_PASSWORD=your-demo-password
# NEXT_PUBLIC_DEMO_EMAIL=demo@your-app.app
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Community features (optional — for GitHub Issue posting)
# GITHUB_COMMUNITY_TOKEN=your-github-pat-with-issues-permission
